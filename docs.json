{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DiHub Documentation",
  "topbarLabels": {
    "onThisPage": "Nesta página"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#6d27d9",
    "light": "#6d27d9",
    "dark": "#6d27d9"
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "bash",
        "javascript",
        "python"
      ],
      "defaults": "all",
      "prefill": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guia",
        "groups": [
          {
            "group": "Introdução",
            "pages": [
              "index",
              "introduction/authentication"
            ]
          },
          {
            "group": "Referência",
            "pages": [
              "reference/consumo-creditos",
              "reference/todas-certidoes"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "Referência da API",
        "groups": [
          {
            "group": "Começando",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "openapi.json get /credits/balance",
              "openapi.json post /diligences/emit",
              "GET /diligences/{id}/status",
              "GET /diligences/{id}/certificates",
              "GET /diligences/{id}/download-pdf",
              "GET /diligences/{id}/download-zip",
              "GET /certificate/{id}/download-pdf"
            ]
          }
        ],
        "openapi": "openapi.json"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "mailto:claudiolima@dihub.com.br"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.dihub.com.br"
    }
  }
}